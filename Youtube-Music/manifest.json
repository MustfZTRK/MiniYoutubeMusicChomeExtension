{
  "manifest_version": 3,
  "name": "Mini Youtube Music",
  "version": "1.4.0",
  "description": "YouTube Music'i eklenti içinde çalıştırın.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "notifications",
    "tabs",
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "Mini Youtube Music"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_ytm",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "options_page": "options/options.html"
}
